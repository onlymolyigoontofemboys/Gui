        -- ──────────────────────────────────────────────────────
        --  Keybind  — FIXED
        --
        --  Root cause of ALL previous bugs:
        --    Old code created a new UIS.InputBegan connection every
        --    time the user clicked the button. After N clicks there
        --    were N live listeners, all with independent `waiting`
        --    closures → they fired on top of each other, captured
        --    random inputs, and called cb() multiple times.
        --
        --  Fix:
        --    • ONE connection created once, tracked, never duplicated.
        --    • `waiting` flag guards it.
        --    • Connection is registered in `_globalConns` → cleaned
        --      when the ScreenGui is destroyed (sg.Destroying fires
        --      cleanAllConns).
        --    • MB1 is explicitly blocked during capture so clicking
        --      the button to cancel doesn't accidentally set MB1.
        --    • Insert is in IGNORED so it never captures the UI key.
        -- ──────────────────────────────────────────────────────
        function Section:AddKeybind(label, default, cb)
            local key     = default or ""
            local waiting = false
            local alive   = true   -- set false when sg destroyed

            local IGNORED = {
                Unknown=true, Insert=true,
                LeftShift=true,   RightShift=true,
                LeftControl=true, RightControl=true,
                LeftAlt=true,     RightAlt=true,
                LeftMeta=true,    RightMeta=true,
                CapsLock=true, NumLock=true, ScrollLock=true,
            }
            local MOUSE = {
                [Enum.UserInputType.MouseButton2]="MB2",
                [Enum.UserInputType.MouseButton3]="MB3",
            }

            local wrap = new("Frame", {Size=UDim2.new(1,0,0,38),BackgroundTransparency=1}, items)
            new("TextLabel", {
                Size=UDim2.new(1,0,0,13), BackgroundTransparency=1,
                Text=label:upper(), TextColor3=TXT_D,
                FontFace=FONT, TextSize=10,
                TextXAlignment=Enum.TextXAlignment.Left,
            }, wrap)
            local bb = new("TextButton", {
                Size=UDim2.new(0.55,0,0,20), Position=UDim2.new(0,0,0,14),
                BackgroundColor3=BG_IN, BorderSizePixel=0,
                Text=key=="" and "[ ... ]" or "[ "..key:upper().." ]",
                TextColor3=TXT, FontFace=FONT, TextSize=11,
                AutoButtonColor=false,
            }, wrap)
            stroke(bb, BOR, 1)
            local xb = new("TextButton", {
                Size=UDim2.new(0,16,0,16), Position=UDim2.new(0.55,4,0,16),
                BackgroundColor3=BG_ITEM, BorderSizePixel=0,
                Text="X", TextColor3=TXT_D, FontFace=FONT, TextSize=9,
                AutoButtonColor=false, Visible=key~="",
            }, wrap)
            stroke(xb, BOR, 1)

            local function setDisplay()
                if not bb.Parent then return end
                bb.Text      = key=="" and "[ ... ]" or "[ "..key:upper().." ]"
                bb.TextColor3= TXT
            end

            local function stopCapture()
                waiting = false
                setDisplay()
            end

            local function capture(name)
                key = name
                stopCapture()
                if xb.Parent then xb.Visible=true end
                if cb then cb(key) end
                Library.Log(label.." keybind -> "..key)
            end

            -- THE ONLY UIS.InputBegan connection for this keybind.
            -- Created once, lives until the window is destroyed.
            local kc = UIS.InputBegan:Connect(function(i)
                -- guard: only active, only while waiting
                if not alive or not waiting then return end

                -- block MB1: that's the cancel click on bb itself
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    return
                end

                -- MB2 / MB3
                local mt = MOUSE[i.UserInputType]
                if mt then capture(mt); return end

                -- Keyboard
                if i.UserInputType == Enum.UserInputType.Keyboard then
                    local kn = i.KeyCode.Name
                    if not IGNORED[kn] then
                        capture(kn)
                    end
                end
            end)
            trackConn(kc)

            -- mark dead when sg is destroyed so the conn body is a no-op
            sg.Destroying:Connect(function() alive=false end)

            bb.MouseButton1Click:Connect(function()
                if not alive then return end
                if waiting then
                    stopCapture()
                else
                    waiting       = true
                    bb.Text       = "[ ? ]"
                    bb.TextColor3 = ACC_LT
                end
            end)

            xb.MouseButton1Click:Connect(function()
                if not alive then return end
                waiting = false
                key     = ""
                setDisplay()
                if xb.Parent then xb.Visible=false end
                if cb then cb(key) end
                Library.Log(label.." keybind cleared")
            end)

            local K={}
            function K:Get() return key end
            function K:Set(v)
                key=v; waiting=false
                setDisplay()
                if xb.Parent then xb.Visible=v~="" end
            end
            return K
        end

