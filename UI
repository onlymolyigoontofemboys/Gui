        local function buildToggleRow(label, default, cb, swatchDefs, logName)
            local state = default==true
            local sc    = #swatchDefs
            local SW    = 18

            local row = new("Frame", {Size=UDim2.new(1,0,0,20),BackgroundTransparency=1}, items)

            local ind = new("Frame", {
                Size=UDim2.new(0,14,0,14), Position=UDim2.new(0,0,0.5,-7),
                BackgroundColor3=state and ACC or BG_DARK, BorderSizePixel=0,
            }, row)
            local indS = stroke(ind, ACC, 1)
            local indL = new("TextLabel", {
                Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
                Text=state and "1" or "0", TextColor3=state and WHITE or ACC,
                FontFace=FONT, TextSize=9,
            }, ind)

            local mainL = new("TextLabel", {
                Size=UDim2.new(1,-(18+sc*(SW+3)+4),1,0),
                Position=UDim2.new(0,18,0,0),
                BackgroundTransparency=1, Text=label:upper(),
                TextColor3=state and TXT_H or TXT,
                FontFace=FONT, TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,
            }, row)

            for idx, sd in ipairs(swatchDefs) do
                local cur=sd.color or ACC; local swCb=sd.cb
                local pOpen=false; local closePick=nil
                local ox = -(idx*(SW+3)) + 3 - SW
                local sw = new("TextButton", {
                    Size=UDim2.new(0,SW,0,14), Position=UDim2.new(1,ox,0.5,-7),
                    BackgroundColor3=cur, BorderSizePixel=0,
                    Text="", AutoButtonColor=false, ZIndex=8,
                }, row)
                stroke(sw, BOR_LT, 1)
                sw.MouseButton1Click:Connect(function()
                    pOpen=not pOpen
                    if closePick then closePick(); closePick=nil end
                    if not pOpen then return end
                    closePick=openColorPicker(sg,sw,cur,function(c)
                        cur=c; sw.BackgroundColor3=c
                        pOpen=false; closePick=nil
                        if swCb then swCb(c) end
                        Library.Log(logName.." color -> "..tostring(c))
                    end)
                end)
            end

            local caOff = sc>0 and -(sc*(SW+3)+4) or -4
            local ca = new("TextButton", {
                Size=UDim2.new(1,caOff,1,0),
                BackgroundTransparency=1, Text="", ZIndex=5,
            }, row)

            ca.MouseButton1Click:Connect(function()
                state=not state
                tw(ind,  {BackgroundColor3=state and ACC or BG_DARK})
                indL.Text       = state and "1" or "0"
                indL.TextColor3 = state and WHITE or ACC
                tw(mainL,{TextColor3=state and TXT_H or TXT})
                if cb then cb(state) end
                Library.Log(logName.." -> "..tostring(state))
            end)

            local T={}
            function T:Set(v)
                state=v
                ind.BackgroundColor3 = state and ACC or BG_DARK
                indL.Text       = state and "1" or "0"
                indL.TextColor3 = state and WHITE or ACC
                if mainL.Parent then mainL.TextColor3=state and TXT_H or TXT end
            end
            function T:Get() return state end
            return T
        end

