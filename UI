-- ── Micro-helpers ─────────────────────────────────────────
local function tw(o, p, ti)
    if not o or not o.Parent then return end
    TS:Create(o, ti or FAST, p):Play()
end

local function new(cl, props, parent)
    local o = Instance.new(cl)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end

local function stroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or BOR; s.Thickness = t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p; return s
end

local function pad(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.Parent = p
end

local function vlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.FillDirection = Enum.FillDirection.Vertical
    l.SortOrder     = Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, gap or 0)
    l.Parent = p; return l
end

local function hlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.FillDirection = Enum.FillDirection.Horizontal
    l.SortOrder     = Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, gap or 0)
    l.Parent = p; return l
end

-- ── Connection registry ───────────────────────────────────
-- All UIS global connections are tracked here and cleaned
-- when the window ScreenGui is destroyed.
local _globalConns = {}
local function trackConn(c)
    table.insert(_globalConns, c)
end
local function cleanAllConns()
    for _, c in ipairs(_globalConns) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(_globalConns)
end

-- ── Slider ────────────────────────────────────────────────
-- No global UIS listener. Uses a capture frame + local InputEnded
-- on the capture frame so it dies automatically when frame is destroyed.
local function makeSlider(track, fill, valLbl, minV, maxV, defV, sfx, cb, capParent)
    sfx = sfx or ""
    local val = math.clamp(defV or minV, minV, maxV)
    local dead = false   -- set true when ScreenGui destroyed

    local function setVal(v)
        val = math.clamp(math.round(v * 10) / 10, minV, maxV)
        local t = (val - minV) / (maxV - minV)
        if fill and fill.Parent then fill.Size = UDim2.new(t, 0, 1, 0) end
        if valLbl and valLbl.Parent then valLbl.Text = tostring(val) .. sfx end
        if cb then cb(val) end
    end
    setVal(val)

    local function getX(x)
        if not track.Parent then return val end
        local ax = track.AbsolutePosition.X
        local aw = track.AbsoluteSize.X
        if aw == 0 then return val end
        return minV + math.clamp((x - ax) / aw, 0, 1) * (maxV - minV)
    end

    local hit = new("TextButton", {
        Size=UDim2.new(1,0,0,16), Position=UDim2.new(0,0,0.5,-8),
        BackgroundTransparency=1, Text="", ZIndex=10,
    }, track)

    local capF = nil
    local function destroyCap()
        if capF then
            local f = capF; capF = nil
            pcall(function() f:Destroy() end)
        end
    end

    hit.MouseButton1Down:Connect(function(mx)
        if dead then return end
        destroyCap()
        setVal(getX(mx))
        capF = new("Frame", {
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, ZIndex=9999,
        }, capParent)
        -- Use the capF's own input events — they die with the frame
        capF.InputChanged:Connect(function(mi)
            if dead then destroyCap(); return end
            if mi.UserInputType == Enum.UserInputType.MouseMovement then
                setVal(getX(mi.Position.X))
            end
        end)
        capF.InputEnded:Connect(function(mi)
            if mi.UserInputType == Enum.UserInputType.MouseButton1 then
                destroyCap()
            end
        end)
    end)

    -- Fallback: one UIS.InputEnded per slider, tracked and cleaned on destroy
    local c = UIS.InputEnded:Connect(function(i)
        if dead then return end
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            destroyCap()
        end
    end)
    trackConn(c)

    local S = {}
    function S:Set(v) if not dead then setVal(v) end end
    function S:Get() return val end
    function S:_kill() dead = true; destroyCap() end
    return S
end

-- ── Color picker ──────────────────────────────────────────
local function openColorPicker(sg, swatchBtn, initColor, cb)
    local pendR, pendG, pendB = initColor.R, initColor.G, initColor.B

    local apos = swatchBtn.AbsolutePosition
    local asiz = swatchBtn.AbsoluteSize
    local pw   = 192
    local px   = apos.X + asiz.X + 6
    local py   = apos.Y - 8
    local vp   = workspace.CurrentCamera.ViewportSize
    if px + pw > vp.X then px = apos.X - pw - 6 end
    if py + 100 > vp.Y then py = vp.Y - 110 end

    local pf = new("Frame", {
        Size=UDim2.new(0,pw,0,0),
        Position=UDim2.new(0,px,0,py),
        BackgroundColor3=BG_ITEM, BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.Y, ZIndex=300,
    }, sg)
    stroke(pf, BOR_LT, 1)
    pad(pf, 8, 8, 10, 10)
    vlist(pf, 6)

    local prevFr = new("Frame", {
        Size=UDim2.new(1,0,0,14),
        BackgroundColor3=initColor, BorderSizePixel=0, ZIndex=301,
    }, pf)
    stroke(prevFr, BOR_LT, 1)

    local chs = {
        {l="R", get=function() return pendR end, set=function(v) pendR=v end, col=Color3.fromRGB(200,50,50)},
        {l="G", get=function() return pendG end, set=function(v) pendG=v end, col=Color3.fromRGB(50,180,50)},
        {l="B", get=function() return pendB end, set=function(v) pendB=v end, col=Color3.fromRGB(60,100,220)},
    }

    for _, ch in ipairs(chs) do
        local cRow = new("Frame", {Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,ZIndex=301}, pf)
        new("TextLabel", {
            Size=UDim2.new(0,10,1,0), BackgroundTransparency=1,
            Text=ch.l, TextColor3=ch.col, FontFace=FONT, TextSize=10, ZIndex=302,
        }, cRow)
        local ct = new("Frame", {
            Size=UDim2.new(1,-38,0,3), Position=UDim2.new(0,13,0.5,-1),
            BackgroundColor3=BG_DARK, BorderSizePixel=0, ZIndex=302,
        }, cRow)
        local cf = new("Frame", {
            Size=UDim2.new(ch.get(),0,1,0),
            BackgroundColor3=ch.col, BorderSizePixel=0, ZIndex=303,
        }, ct)
        local cl = new("TextLabel", {
            Size=UDim2.new(0,24,1,0), Position=UDim2.new(1,-24,0,-4),
            BackgroundTransparency=1, Text=tostring(math.round(ch.get()*255)),
            TextColor3=TXT_D, FontFace=FONT, TextSize=9, ZIndex=302,
        }, cRow)

        local hit2 = new("TextButton", {
            Size=UDim2.new(1,0,0,16), Position=UDim2.new(0,0,0.5,-8),
            BackgroundTransparency=1, Text="", ZIndex=310,
        }, ct)

        local capC = nil
        local function destroyCapC()
            if capC then local f=capC; capC=nil; pcall(function() f:Destroy() end) end
        end
        local function calcCol(x)
            if not ct.Parent then return end
            local t = math.clamp((x - ct.AbsolutePosition.X) / math.max(ct.AbsoluteSize.X,1), 0, 1)
            ch.set(t)
            cf.Size = UDim2.new(t,0,1,0)
            cl.Text = tostring(math.round(t*255))
            prevFr.BackgroundColor3 = Color3.new(pendR,pendG,pendB)
        end

        hit2.MouseButton1Down:Connect(function(mx)
            destroyCapC()
            calcCol(mx)
            capC = new("Frame", {Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=9999}, sg)
            capC.InputChanged:Connect(function(mi)
                if mi.UserInputType==Enum.UserInputType.MouseMovement then calcCol(mi.Position.X) end
            end)
            capC.InputEnded:Connect(function(mi)
                if mi.UserInputType==Enum.UserInputType.MouseButton1 then destroyCapC() end
            end)
        end)

        local uc = UIS.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then destroyCapC() end
        end)
        trackConn(uc)
    end

    local apply = new("TextButton", {
        Size=UDim2.new(1,0,0,20), BackgroundColor3=ACC_DK, BorderSizePixel=0,
        Text="APPLY", TextColor3=ACC_LT, FontFace=FONT, TextSize=11,
        AutoButtonColor=false, ZIndex=301,
    }, pf)
    stroke(apply, ACC, 1)

    apply.MouseButton1Click:Connect(function()
        if cb then cb(Color3.new(pendR,pendG,pendB)) end
        if pf.Parent then pf:Destroy() end
    end)

    return function()
        if pf and pf.Parent then pf:Destroy() end
    end
end

-- ── Notify ────────────────────────────────────────────────
local NotifySG
local ActiveNotifs = {}

local function ensureNSG()
    if NotifySG and NotifySG.Parent then return end
    NotifySG = new("ScreenGui", {
        Name="LibNotify", ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling, DisplayOrder=999,
    }, CG)
end

local function reflow(pos)
    local off = 0
    for i = #ActiveNotifs, 1, -1 do
        local f  = ActiveNotifs[i]
        if not f.Parent then table.remove(ActiveNotifs,i); continue end
        local fw = f.Size.X.Offset
        local fh = f.Size.Y.Offset
        local t
        if     pos=="Top"    then t=UDim2.new(0.5,-fw/2, 0, 12+off)
        elseif pos=="Bottom" then t=UDim2.new(0.5,-fw/2, 1,-12-fh-off)
        elseif pos=="Left"   then t=UDim2.new(0,12, 0.5,-fh/2-off)
        else                      t=UDim2.new(1,-fw-12, 0.5,-fh/2-off)
        end
        tw(f, {Position=t}, TweenInfo.new(0.18,Enum.EasingStyle.Quart,Enum.EasingDirection.Out))
        off = off + fh + 5
    end
end

-- ── Library ───────────────────────────────────────────────
local Library = {}

function Library.Log(msg)
    print("[Library] " .. tostring(msg))
end

function Library.Notify(text, pos, dur)
    pos = pos or "Right"
    dur = dur or 3.5
    ensureNSG()

    local up = text:upper()
    local dummy = new("TextLabel", {
        Size=UDim2.new(0,600,0,20), Text=up,
        FontFace=FONT, TextSize=12, Visible=false,
    }, NotifySG)
    local fw = math.max(120, dummy.TextBounds.X + 36)
    dummy:Destroy()
    local fh = 28

    local sp
    if     pos=="Top"    then sp=UDim2.new(0.5,-fw/2, 0,-fh-10)
    elseif pos=="Bottom" then sp=UDim2.new(0.5,-fw/2, 1, fh+10)
    elseif pos=="Left"   then sp=UDim2.new(0,-fw-10, 0.5,-fh/2)
    else                      sp=UDim2.new(1, fw+10, 0.5,-fh/2)
    end

    local fr = new("Frame", {
        Size=UDim2.new(0,fw,0,fh), Position=sp,
        BackgroundColor3=BG_H, BorderSizePixel=0,
        ClipsDescendants=true, ZIndex=100,
    }, NotifySG)
    stroke(fr, BOR, 1)
    new("Frame", {Size=UDim2.new(0,2,1,0), BackgroundColor3=ACC, BorderSizePixel=0, ZIndex=101}, fr)
    local lbl = new("TextLabel", {
        Size=UDim2.new(1,-12,1,0), Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1, Text="", TextColor3=TXT_H,
        FontFace=FONT, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=101,
    }, fr)
    local bar = new("Frame", {
        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=ACC, BorderSizePixel=0, ZIndex=102,
    }, fr)

    table.insert(ActiveNotifs, fr)
    reflow(pos)
    TS:Create(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,0,1)}):Play()

    task.spawn(function()
        for i = 1, #up do
            if not lbl.Parent then return end
            lbl.Text = string.sub(up, 1, i)
            task.wait(0.022)
        end
    end)

    task.delay(dur, function()
        for i, v in ipairs(ActiveNotifs) do
            if v==fr then table.remove(ActiveNotifs,i); break end
        end
        reflow(pos)
        if not fr.Parent then return end
        local ep
        local px2=fr.Position.X.Offset; local py2=fr.Position.Y.Offset
        local xs=fr.Position.X.Scale;   local ys=fr.Position.Y.Scale
        if     pos=="Top"    then ep=UDim2.new(xs,px2,0,-fh-10)
        elseif pos=="Bottom" then ep=UDim2.new(xs,px2,1,fh+10)
        elseif pos=="Left"   then ep=UDim2.new(0,-fw-10,ys,py2)
        else                      ep=UDim2.new(1,fw+10,ys,py2)
        end
        local tt = TS:Create(fr, TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In),
            {Position=ep, BackgroundTransparency=1})
        tt:Play()
        tt.Completed:Connect(function() pcall(function() fr:Destroy() end) end)
    end)
end

-- ── CreateWindow ─────────────────────────────────────────
function Library.CreateWindow()
    -- kill any leftover from previous run
    local old = CG:FindFirstChild("Library")
    if old then old:Destroy() end
    cleanAllConns()  -- clean previous window's connections

    local sg = new("ScreenGui", {
        Name="Library", ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
    }, CG)

    -- When the ScreenGui is destroyed (script rerun / explicit destroy),
    -- disconnect every global UIS connection this library created.
    sg.Destroying:Connect(cleanAllConns)

    local win = new("Frame", {
        Size=UDim2.new(0,640,0,420),
        Position=UDim2.new(0.5,-320,0.5,-210),
        BackgroundColor3=BG, BorderSizePixel=0, ClipsDescendants=true,
    }, sg)
    stroke(win, BOR, 1)

    local fadeOverlay = new("Frame", {
        Size=UDim2.new(1,0,1,0), BackgroundColor3=Color3.fromRGB(0,0,0),
        BackgroundTransparency=1, BorderSizePixel=0, ZIndex=500, Visible=false,
    }, win)

    local visible = true
    do
        local c = UIS.InputBegan:Connect(function(i, gpe)
            if gpe then return end
            if i.KeyCode ~= Enum.KeyCode.Insert then return end
            if not win.Parent then return end
            if visible then
                visible = false
                fadeOverlay.Visible = true
                fadeOverlay.BackgroundTransparency = 1
                tw(fadeOverlay, {BackgroundTransparency=0}, MED)
                task.delay(0.22, function()
                    if win.Parent then win.Visible=false end
                    if fadeOverlay.Parent then fadeOverlay.Visible=false end
                end)
            else
                visible = true
                win.Visible = true
                fadeOverlay.Visible = true
                fadeOverlay.BackgroundTransparency = 0
                tw(fadeOverlay, {BackgroundTransparency=1}, MED)
                task.delay(0.22, function()
                    if fadeOverlay.Parent then fadeOverlay.Visible=false end
                end)
            end
        end)
        trackConn(c)
    end

    -- drag
    local header = new("Frame", {
        Size=UDim2.new(1,0,0,36), BackgroundColor3=BG_H,
        BorderSizePixel=0, ZIndex=5,
    }, win)
    new("Frame", {
        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=BOR, BorderSizePixel=0, ZIndex=5,
    }, header)
    do
        local drag=false; local ds,sp2=nil,nil
        header.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                drag=true; ds=i.Position; sp2=win.Position
            end
        end)
        local c1 = UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement and win.Parent then
                local d=i.Position-ds
                win.Position=UDim2.new(sp2.X.Scale,sp2.X.Offset+d.X,sp2.Y.Scale,sp2.Y.Offset+d.Y)
            end
        end)
        local c2 = UIS.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        trackConn(c1); trackConn(c2)
    end

    local tabRow = new("Frame", {
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, ZIndex=6,
    }, header)
    hlist(tabRow, 0)

    local content = new("Frame", {
        Size=UDim2.new(1,0,1,-36), Position=UDim2.new(0,0,0,36),
        BackgroundTransparency=1, ClipsDescendants=true,
    }, win)

    local Window    = {}
    local activeTab = nil
    local tabCount  = 0

    local function activateTab(tab)
        if activeTab==tab then return end
        if activeTab then
            activeTab.frame.Visible=false
            tw(activeTab.btn, {TextColor3=TXT_D})
            activeTab.line.BackgroundTransparency=1
        end
        activeTab=tab
        tab.frame.Visible=true
        tw(tab.btn, {TextColor3=TXT_H})
        tw(tab.line, {BackgroundTransparency=0})
        Library.Log("Tab -> " .. tab.name)
    end

    -- Dialog
    local dlgOv = new("Frame", {
        Size=UDim2.new(1,0,1,0), BackgroundColor3=Color3.fromRGB(0,0,0),
        BackgroundTransparency=1, BorderSizePixel=0, Visible=false, ZIndex=50,
    }, win)
    local dlgBox = new("Frame", {
        Size=UDim2.new(0,300,0,80), Position=UDim2.new(0.5,-150,0.5,-40),
        BackgroundColor3=BG, BorderSizePixel=0, ZIndex=51,
    }, dlgOv)
    stroke(dlgBox, BOR_LT, 1)
    local dlgTxt = new("TextLabel", {
        Size=UDim2.new(1,-20,0,36), Position=UDim2.new(0,10,0,8),
        BackgroundTransparency=1, Text="", TextColor3=TXT,
        FontFace=FONT, TextSize=12, TextWrapped=true, ZIndex=52,
    }, dlgBox)
    local dlgY = new("TextButton", {
        Size=UDim2.new(0,76,0,20), Position=UDim2.new(0.5,-80,1,-28),
        BackgroundColor3=ACC_DK, BorderSizePixel=0,
        Text="YES", TextColor3=ACC_LT, FontFace=FONT, TextSize=11,
        AutoButtonColor=false, ZIndex=52,
    }, dlgBox)
    stroke(dlgY, ACC, 1)
    local dlgN = new("TextButton", {
        Size=UDim2.new(0,76,0,20), Position=UDim2.new(0.5,4,1,-28),
        BackgroundColor3=BG_ITEM, BorderSizePixel=0,
        Text="NO", TextColor3=TXT, FontFace=FONT, TextSize=11,
        AutoButtonColor=false, ZIndex=52,
    }, dlgBox)
    stroke(dlgN, BOR, 1)
    local dlgCb=nil
    local function closeDlg(r)
        tw(dlgOv, {BackgroundTransparency=1})
        task.delay(0.18, function()
            if dlgOv.Parent then dlgOv.Visible=false end
        end)
        if dlgCb then dlgCb(r); dlgCb=nil end
        Library.Log("Dialog -> " .. tostring(r))
    end
    dlgY.MouseButton1Click:Connect(function() closeDlg(true) end)
    dlgN.MouseButton1Click:Connect(function() closeDlg(false) end)
    function Window:Dialog(msg, cb)
        dlgTxt.Text=msg:upper(); dlgCb=cb
        dlgOv.Visible=true
        tw(dlgOv, {BackgroundTransparency=0.6})
        Library.Log("Dialog: " .. msg)
    end

    -- ────────────────────────────────────────────────────────
    --  buildSection
    -- ────────────────────────────────────────────────────────
    local function buildSection(container, sName, showTitle)
        local items

        if showTitle then
            local wrapper = new("Frame", {
                Size=UDim2.new(1,0,0,0), BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,
            }, container)
            vlist(wrapper, 4)
            if sName and sName ~= "" then
                new("TextLabel", {
                    Size=UDim2.new(1,0,0,14), BackgroundTransparency=1,
                    Text=sName:upper(), TextColor3=TXT_D,
                    FontFace=FONT, TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,
                }, wrapper)
            end
            items = new("Frame", {
                Size=UDim2.new(1,0,0,0), BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,
            }, wrapper)
            vlist(items, 3)
        else
            items = new("Frame", {
                Size=UDim2.new(1,0,0,0), BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,
            }, container)
            vlist(items, 3)
        end

        local Section = {}

        -- SubTabs
        function Section:AddSubTabs(tabList, cb)
            local btnRow = new("Frame", {Size=UDim2.new(1,0,0,22),BackgroundTransparency=1}, items)
            hlist(btnRow, 4)
