-- Notification system (Library.Notify style)
-- ══════════════════════════════════════════════════════════════════════════
local NotifySG     = nil
local ActiveNotifs = {}

local function ensureNSG()
    if NotifySG and NotifySG.Parent then return end
    NotifySG = new("ScreenGui", {
        Name = "LdrNotifs", ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, DisplayOrder = 999,
    }, CG)
end

local function reflow(pos)
    local GAP = 5
    local alive = {}
    for _, fr in ipairs(ActiveNotifs) do
        if fr and fr.Parent then table.insert(alive, fr) end
    end
    for i, fr in ipairs(alive) do
        local fh = fr.Size.Y.Offset
        local fw = fr.Size.X.Offset
        if pos == "Right" then
            tw(fr, {Position = UDim2.new(1, -fw - 10, 1, -(fh + GAP) * i)},
                ease(0.22, Enum.EasingStyle.Quart))
        elseif pos == "Left" then
            tw(fr, {Position = UDim2.new(0, 10, 1, -(fh + GAP) * i)},
                ease(0.22, Enum.EasingStyle.Quart))
        elseif pos == "Top" then
            tw(fr, {Position = UDim2.new(0.5, -fw/2, 0, (fh + GAP) * (i-1) + 10)},
                ease(0.22, Enum.EasingStyle.Quart))
        elseif pos == "Bottom" then
            tw(fr, {Position = UDim2.new(0.5, -fw/2, 1, -(fh + GAP) * i)},
                ease(0.22, Enum.EasingStyle.Quart))
        end
    end
end

local function Notify(text, pos, dur, accentCol)
    pos       = pos       or "Right"
    dur       = dur       or 3.5
    accentCol = accentCol or C.acc
    ensureNSG()

    local up = text:upper()

    local dummy = new("TextLabel", {
        Size = UDim2.new(0, 600, 0, 20), Text = up,
        FontFace = FONT, TextSize = 13, Visible = false,
    }, NotifySG)
    local fw = math.max(90, dummy.TextBounds.X + 28)
    dummy:Destroy()
    local fh = 28

    local sp
    if     pos == "Top"    then sp = UDim2.new(0.5, -fw/2, 0, -fh - 10)
    elseif pos == "Bottom" then sp = UDim2.new(0.5, -fw/2, 1,  fh + 10)
    elseif pos == "Left"   then sp = UDim2.new(0, -fw - 10, 0.5, -fh/2)
    else                        sp = UDim2.new(1,  fw + 10, 0.5, -fh/2)
    end

    local fr = new("Frame", {
        Size = UDim2.new(0, fw, 0, fh), Position = sp,
        BackgroundColor3 = C.bgIn, BackgroundTransparency = 0.06,
        BorderSizePixel = 0, ClipsDescendants = true, ZIndex = 100,
    }, NotifySG)
    corner(fr, 3)
    stroke(fr, C.bor, 1)

    new("Frame", {
        Size = UDim2.new(0, 2, 1, 0),
        BackgroundColor3 = accentCol, BorderSizePixel = 0, ZIndex = 101,
    }, fr)
    new("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = accentCol, BorderSizePixel = 0, ZIndex = 101,
    }, fr)

    local lbl = new("TextLabel", {
        Size = UDim2.new(1, -14, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = "", TextColor3 = C.txtH,
        FontFace = FONT, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101,
    }, fr)
    local bar = new("Frame", {
        Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = accentCol, BorderSizePixel = 0, ZIndex = 102,
    }, fr)

    table.insert(ActiveNotifs, fr)
    reflow(pos)

    TS:Create(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 1)}):Play()
    task.spawn(function()
        for i = 1, #up do
            if not lbl or not lbl.Parent then return end
            lbl.Text = string.sub(up, 1, i); task.wait(0.025)
        end
    end)

    task.delay(dur, function()
        for i, v in ipairs(ActiveNotifs) do
            if v == fr then table.remove(ActiveNotifs, i); break end
        end
        reflow(pos)
        local px2 = fr.Position.X.Offset; local py2 = fr.Position.Y.Offset
        local xs  = fr.Position.X.Scale;  local ys  = fr.Position.Y.Scale
        local ep
        if     pos == "Top"    then ep = UDim2.new(xs, px2, 0, -fh - 10)
        elseif pos == "Bottom" then ep = UDim2.new(xs, px2, 1,  fh + 10)
        elseif pos == "Left"   then ep = UDim2.new(0, -fw - 10, ys, py2)
        else                        ep = UDim2.new(1,  fw + 10, ys, py2)
        end
        local tt = TS:Create(fr, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = ep, BackgroundTransparency = 1,
        })
        tt:Play()
        tt.Completed:Connect(function() fr:Destroy() end)
    end)
end

