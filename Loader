local TS  = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local CG  = game:GetService("CoreGui")

local FONT
do
    local ok = pcall(function()
        local aid = "SmallestPixel.ttf"
        if not isfile(aid) then
            writefile(aid, game:HttpGet(
                "https://raw.githubusercontent.com/onlymolyigoontofemboys/BETA/main/smallest_pixel-7.ttf"
            ))
        end
        FONT = Font.new(getcustomasset(aid))
    end)
    if not ok then FONT = Font.new("rbxasset://fonts/families/RobotoMono.json") end
end

local C = {
    bg        = Color3.fromRGB(16, 16, 18),
    panel     = Color3.fromRGB(22, 22, 24),
    item      = Color3.fromRGB(26, 26, 28),
    itemHov   = Color3.fromRGB(30, 30, 32),
    itemSel   = Color3.fromRGB(22, 34, 24),
    bor       = Color3.fromRGB(48, 48, 52),
    borLight  = Color3.fromRGB(62, 62, 66),
    acc       = Color3.fromRGB(72, 196, 100),
    accGlow   = Color3.fromRGB(50, 140, 70),
    accDark   = Color3.fromRGB(30, 70, 40),
    txt       = Color3.fromRGB(188, 188, 192),
    txtD      = Color3.fromRGB(88, 88, 94),
    txtH      = Color3.fromRGB(224, 224, 228),
    yellow    = Color3.fromRGB(236, 190, 48),
    red       = Color3.fromRGB(210, 65, 65),
    redDark   = Color3.fromRGB(38, 14, 14),
    btnBg     = Color3.fromRGB(30, 30, 32),
    btnHov    = Color3.fromRGB(38, 38, 42),
    black     = Color3.fromRGB(0, 0, 0),
}

local function ease(t, s, d)
    return TweenInfo.new(t, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out)
end

local T_FAST  = ease(0.14)
local T_MED   = ease(0.24)
local T_SLOW  = ease(0.38)
local T_SPRING= ease(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

local function tw(obj, props, ti)
    TS:Create(obj, ti or T_FAST, props):Play()
end

local function new(cl, props, parent)
    local o = Instance.new(cl)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end

local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 3)
    c.Parent = p
end

local function stroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or C.bor
    s.Thickness = t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function pad(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.Parent = p
end

local function vlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.FillDirection = Enum.FillDirection.Vertical
    l.SortOrder     = Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, gap or 0)
    l.Parent = p
    return l
end

local function typewrite(lbl, text, speed)
    speed = speed or 0.03
    task.spawn(function()
        for i = 1, #text do
            if not lbl or not lbl.Parent then return end
            lbl.Text = string.sub(text, 1, i)
            task.wait(speed)
        end
    end)
end

local Loader = {}

function Loader.CreateWindow(config)
    config = config or {}

    local old = CG:FindFirstChild("LoaderUI")
    if old then old:Destroy() end

    local sg = new("ScreenGui", {
        Name           = "LoaderUI",
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    }, CG)

    local W, H     = 490, 310
    local LEFT_W   = 272
    local RIGHT_W  = W - LEFT_W - 1
    local STATUS_H = 112
    local TOP_H    = H - STATUS_H - 1

    local bgOverlay = new("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = C.black,
        BackgroundTransparency = 0,
        BorderSizePixel  = 0,
        ZIndex           = 0,
    }, sg)

    local win = new("Frame", {
        Size             = UDim2.new(0, W, 0, H),
        Position         = UDim2.new(0.5, -W/2, 0.5, -H/2 + 24),
        BackgroundColor3 = C.bg,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        BackgroundTransparency = 1,
        ZIndex           = 2,
    }, sg)
    local winStroke = stroke(win, C.bor, 1)

    do
        local drag, ds, sp = false, nil, nil
        win.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true; ds = i.Position; sp = win.Position
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - ds
                win.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
            end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
        end)
    end

    local listPanel = new("Frame", {
        Size             = UDim2.new(0, LEFT_W, 0, TOP_H),
        BackgroundColor3 = C.panel,
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }, win)

    local divV = new("Frame", {
        Size             = UDim2.new(0, 1, 0, TOP_H),
        Position         = UDim2.new(0, LEFT_W, 0, 0),
        BackgroundColor3 = C.bor,
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }, win)

    local optPanel = new("Frame", {
        Size             = UDim2.new(0, RIGHT_W, 0, TOP_H),
        Position         = UDim2.new(0, LEFT_W+1, 0, 0),
        BackgroundColor3 = C.panel,
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }, win)

    local divH = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 0, TOP_H),
        BackgroundColor3 = C.bor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, win)

    local statusPanel = new("Frame", {
        Size             = UDim2.new(1, 0, 0, STATUS_H),
        Position         = UDim2.new(0, 0, 0, TOP_H+1),
        BackgroundColor3 = C.bg,
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }, win)

    local scriptScroll = new("ScrollingFrame", {
        Size                 = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 2,
        ScrollBarImageColor3 = C.bor,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ClipsDescendants     = true,
        ZIndex               = 2,
    }, listPanel)
    vlist(scriptScroll, 0)

    local optTitleLbl = new("TextLabel", {
        Size             = UDim2.new(1, -14, 0, 26),
        Position         = UDim2.new(0, 8, 0, 4),
        BackgroundTransparency = 1,
        Text             = "Options",
        TextColor3       = C.txtH,
        FontFace         = FONT,
        TextSize         = 13,
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 3,
    }, optPanel)

    new("Frame", {
        Size             = UDim2.new(1, -16, 0, 1),
        Position         = UDim2.new(0, 8, 0, 30),
        BackgroundColor3 = C.bor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, optPanel)

    local optArea = new("Frame", {
        Size             = UDim2.new(1, -16, 1, -40),
        Position         = UDim2.new(0, 8, 0, 38),
        BackgroundTransparency = 1,
        ZIndex           = 3,
    }, optPanel)
    vlist(optArea, 6)

    local statusHeader = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 20),
        BackgroundColor3 = C.panel,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, statusPanel)

    local statusDot = new("Frame", {
        Size             = UDim2.new(0, 5, 0, 5),
        Position         = UDim2.new(0, 8, 0.5, -2),
        BackgroundColor3 = C.acc,
        BorderSizePixel  = 0,
        ZIndex           = 4,
    }, statusHeader)
    corner(statusDot, 3)

    new("TextLabel", {
        Size             = UDim2.new(1, -24, 1, 0),
        Position         = UDim2.new(0, 18, 0, 0),
        BackgroundTransparency = 1,
        Text             = "Status",
        TextColor3       = C.txtH,
        FontFace         = FONT,
        TextSize         = 11,
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 4,
    }, statusHeader)

    new("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = C.bor,
        BorderSizePixel  = 0,
        ZIndex           = 4,
    }, statusHeader)

    local statusBody = new("ScrollingFrame", {
        Size                 = UDim2.new(1, 0, 1, -20),
        Position             = UDim2.new(0, 0, 0, 20),
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 2,
        ScrollBarImageColor3 = C.bor,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ClipsDescendants     = true,
        ZIndex               = 3,
    }, statusPanel)
    pad(statusBody, 6, 6, 10, 10)
    vlist(statusBody, 3)

    local loadingBar = new("Frame", {
        Size             = UDim2.new(0, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = C.acc,
        BorderSizePixel  = 0,
        ZIndex           = 10,
    }, win)

    local function animateLoadBar()
        tw(loadingBar, {Size = UDim2.new(0.6, 0, 0, 1)}, ease(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out))
        task.delay(0.85, function()
            tw(loadingBar, {Size = UDim2.new(1, 0, 0, 1)}, ease(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In))
            task.delay(0.35, function()
                tw(loadingBar, {Size = UDim2.new(0, 0, 0, 1)}, ease(0.2))
            end)
        end)
    end

    local function makeBtn(text, danger)
        local btn = new("TextButton", {
            Size             = UDim2.new(1, 0, 0, 28),
            BackgroundColor3 = C.btnBg,
            BorderSizePixel  = 0,
            Text             = text,
            TextColor3       = danger and C.red or C.txt,
            FontFace         = FONT,
            TextSize         = 12,
            AutoButtonColor  = false,
            ZIndex           = 4,
            BackgroundTransparency = 1,
        }, optArea)
        local bs = stroke(btn, danger and Color3.fromRGB(70, 26, 26) or C.bor, 1)

        btn.MouseEnter:Connect(function()
            tw(btn, {
                BackgroundColor3     = danger and C.redDark or C.btnHov,
                BackgroundTransparency = 0,
                TextColor3           = danger and Color3.fromRGB(230, 90, 90) or C.txtH,
            }, T_FAST)
            bs.Color = danger and C.red or C.borLight
        end)
        btn.MouseLeave:Connect(function()
            tw(btn, {
                BackgroundColor3     = C.btnBg,
                BackgroundTransparency = 1,
                TextColor3           = danger and C.red or C.txt,
            }, T_FAST)
            bs.Color = danger and Color3.fromRGB(70, 26, 26) or C.bor
        end)
        btn.MouseButton1Click:Connect(function()
            tw(btn, {BackgroundColor3 = danger and Color3.fromRGB(50,14,14) or Color3.fromRGB(44,44,50), BackgroundTransparency=0}, T_FAST)
            task.delay(0.12, function()
                tw(btn, {BackgroundColor3 = C.btnBg, BackgroundTransparency=1}, T_FAST)
            end)
            animateLoadBar()
        end)
        return btn
    end

    local loadBtn = makeBtn("Load",  false)
    local exitBtn = makeBtn("Exit",  true)

    local selected = nil
    local scripts  = {}
    local Window   = {}

    function Window:AddScript(def)
        local name   = def.name   or "Script"
        local date   = def.date   or ""
        local icon   = def.icon   or nil
        local onLoad = def.onLoad or nil

        local ITEM_H = 50
        local idx    = #scripts + 1

        local item = new("Frame", {
            Size             = UDim2.new(1, 0, 0, ITEM_H),
            BackgroundColor3 = C.item,
            BorderSizePixel  = 0,
            ZIndex           = 3,
            BackgroundTransparency = 1,
        }, scriptScroll)

        new("Frame", {
            Size             = UDim2.new(1, 0, 0, 1),
            Position         = UDim2.new(0, 0, 1, -1),
            BackgroundColor3 = C.bor,
            BackgroundTransparency = 0.5,
            BorderSizePixel  = 0,
            ZIndex           = 4,
        }, item)

        local selBar = new("Frame", {
            Size                 = UDim2.new(0, 2, 0, 0),
            Position             = UDim2.new(0, 0, 0.5, 0),
            BackgroundColor3     = C.acc,
            BorderSizePixel      = 0,
            ZIndex               = 5,
        }, item)

        local ICON_S = 32
        local iconBg = new("Frame", {
            Size             = UDim2.new(0, ICON_S, 0, ICON_S),
            Position         = UDim2.new(0, 10, 0.5, -ICON_S/2),
            BackgroundColor3 = C.bg,
            BorderSizePixel  = 0,
            ZIndex           = 4,
        }, item)
        corner(iconBg, 3)
        stroke(iconBg, C.bor, 1)

        if icon then
            new("ImageLabel", {
                Size                 = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Image                = icon,
                ZIndex               = 5,
            }, iconBg)
        else
            new("TextLabel", {
                Size                 = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text                 = string.sub(name, 1, 1):upper(),
                TextColor3           = C.accGlow,
                FontFace             = FONT,
                TextSize             = 15,
                ZIndex               = 5,
            }, iconBg)
        end

        local TX = 10 + ICON_S + 10

        local nameLbl = new("TextLabel", {
            Size             = UDim2.new(1, -(TX+8), 0, 16),
            Position         = UDim2.new(0, TX, 0, 11),
            BackgroundTransparency = 1,
            Text             = name,
            TextColor3       = C.accGlow,
            FontFace         = FONT,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 4,
        }, item)

        new("TextLabel", {
            Size             = UDim2.new(1, -(TX+8), 0, 12),
            Position         = UDim2.new(0, TX, 0, 28),
            BackgroundTransparency = 1,
            Text             = "Updated " .. date,
            TextColor3       = C.txtD,
            FontFace         = FONT,
            TextSize         = 10,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 4,
        }, item)

        local hitbox = new("TextButton", {
            Size                 = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                 = "",
            ZIndex               = 6,
        }, item)

        local entry = {item=item, onLoad=onLoad, nameLbl=nameLbl, selBar=selBar, iconBg=iconBg}
        table.insert(scripts, entry)

        local function selectEntry()
            if selected and selected ~= entry then
                local prev = selected
                tw(prev.item,    {BackgroundColor3=C.item,  BackgroundTransparency=1},  T_MED)
                tw(prev.nameLbl, {TextColor3=C.accGlow}, T_FAST)
                tw(prev.selBar,  {Size=UDim2.new(0,2,0,0), Position=UDim2.new(0,0,0.5,0)}, T_MED)
            end
            selected = entry
            tw(item,    {BackgroundColor3=C.itemSel, BackgroundTransparency=0}, T_MED)
            tw(nameLbl, {TextColor3=C.acc}, T_FAST)
            tw(selBar,  {Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,0,0,0)}, T_SPRING)
        end

        hitbox.MouseEnter:Connect(function()
            if selected ~= entry then
                tw(item, {BackgroundColor3=C.itemHov, BackgroundTransparency=0}, T_FAST)
            end
        end)
        hitbox.MouseLeave:Connect(function()
            if selected ~= entry then
                tw(item, {BackgroundColor3=C.item, BackgroundTransparency=1}, T_FAST)
            end
        end)
        hitbox.MouseButton1Click:Connect(function()
            selectEntry()
        end)

        task.delay(0.05 * idx, function()
            if not item.Parent then return end
            tw(item, {BackgroundTransparency = selected==entry and 0 or 1}, T_MED)
        end)

        if #scripts == 1 then
            task.defer(selectEntry)
        end
    end

    function Window:SetStatus(lines)
        for _, c in ipairs(statusBody:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end

        local dot = statusDot
        tw(dot, {BackgroundColor3 = C.acc}, T_FAST)

        for i, def in ipairs(lines) do
            local col
            if     def.color == "yellow" then col = C.yellow
            elseif def.color == "green"  then col = C.acc
            elseif def.color == "red"    then col = C.red
            else                              col = C.txt
            end

            local lbl = new("TextLabel", {
                Size                 = UDim2.new(1, 0, 0, 14),
                BackgroundTransparency = 1,
                Text                 = "",
                TextColor3           = col,
                FontFace             = FONT,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
                TextWrapped          = true,
                ZIndex               = 4,
                TextTransparency     = 1,
            }, statusBody)

            task.delay(0.08 * (i-1), function()
                if not lbl.Parent then return end
                tw(lbl, {TextTransparency=0}, T_MED)
                typewrite(lbl, def.text or "", 0.018)
            end)
        end
    end

    function Window:OnLoad(cb)
        loadBtn.MouseButton1Click:Connect(function()
            if selected and selected.onLoad then selected.onLoad() end
            if cb then cb(selected) end
        end)
    end

    function Window:OnExit(cb)
        exitBtn.MouseButton1Click:Connect(function()
            tw(bgOverlay, {BackgroundTransparency=0}, ease(0.2))
            tw(win,       {BackgroundTransparency=1, Position=UDim2.new(0.5,-W/2,0.5,-H/2+16)}, ease(0.2))
            task.delay(0.22, function()
                if cb then cb() end
                sg:Destroy()
            end)
        end)
    end

    function Window:AddOption(text, danger, cb)
        local btn = makeBtn(text, danger)
        btn.MouseButton1Click:Connect(function()
            if cb then cb(selected) end
        end)
    end

    function Window:Destroy()
        sg:Destroy()
    end

    task.spawn(function()
        tw(bgOverlay, {BackgroundTransparency=0.55}, ease(0.3))
        task.wait(0.05)
        tw(win, {
            BackgroundTransparency = 0,
            Position = UDim2.new(0.5, -W/2, 0.5, -H/2),
        }, T_SPRING)
        winStroke.Transparency = 0
    end)

    return Window
end

return Loader
