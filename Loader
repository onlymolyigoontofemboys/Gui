    local function animateLoadBar()
        tw(loadingBar, {Size=UDim2.new(0.6,0,0,1)}, ease(0.8,Enum.EasingStyle.Quad,Enum.EasingDirection.Out))
        task.delay(0.85, function()
            tw(loadingBar, {Size=UDim2.new(1,0,0,1)}, ease(0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In))
            task.delay(0.35, function()
                tw(loadingBar, {Size=UDim2.new(0,0,0,1)}, ease(0.2))
            end)
        end)
    end

    -- ── Status output helper ───────────────────────────────────────────────
    local function appendStatus(text, color)
        local col
        if     color=="yellow" then col=C.yellow
        elseif color=="green"  then col=C.green
        elseif color=="red"    then col=C.red
        elseif color=="accent" then col=C.accLt
        else                        col=C.txt
        end
        local lbl = new("TextLabel",{
            Size=UDim2.new(1,0,0,14),
            BackgroundTransparency=1,
            Text="",
            TextColor3=col, FontFace=FONT, TextSize=12,
            TextXAlignment=Enum.TextXAlignment.Left,
            TextWrapped=true, ZIndex=4,
            TextTransparency=1,
        }, statusBody)
        tw(lbl, {TextTransparency=0}, T_MED)
        typewrite(lbl, text, 0.018)
        -- auto scroll to bottom
        task.delay(0.05, function()
            if statusBody and statusBody.Parent then
                statusBody.CanvasPosition = Vector2.new(0, math.huge)
            end
        end)
    end

    -- ── Button factory ────────────────────────────────────────────────────
    local function makeBtn(text, danger)
        local btn = new("TextButton",{
            Size=UDim2.new(1,0,0,28),
            BackgroundColor3=C.btnBg, BorderSizePixel=0,
            Text=text, TextColor3=danger and C.red or C.txt,
            FontFace=FONT, TextSize=12,
            AutoButtonColor=false, ZIndex=4,
            BackgroundTransparency=1,
        }, optArea)
        local bs = stroke(btn, danger and Color3.fromRGB(70,26,26) or C.bor, 1)
        btn.MouseEnter:Connect(function()
            tw(btn,{BackgroundColor3=danger and C.accDark or C.btnHov,BackgroundTransparency=0,TextColor3=danger and Color3.fromRGB(230,90,90) or C.txtH},T_FAST)
            bs.Color = danger and C.red or C.borLt
        end)
        btn.MouseLeave:Connect(function()
            tw(btn,{BackgroundColor3=C.btnBg,BackgroundTransparency=1,TextColor3=danger and C.red or C.txt},T_FAST)
            bs.Color = danger and Color3.fromRGB(70,26,26) or C.bor
        end)
        btn.MouseButton1Click:Connect(function()
            tw(btn,{BackgroundColor3=danger and Color3.fromRGB(50,14,14) or Color3.fromRGB(44,44,50),BackgroundTransparency=0},T_FAST)
            task.delay(0.12,function() tw(btn,{BackgroundColor3=C.btnBg,BackgroundTransparency=1},T_FAST) end)
            animateLoadBar()
        end)
        return btn
    end

    local loadBtn = makeBtn("Load",  false)
    local exitBtn = makeBtn("Exit",  true)

    local selected = nil
    local scripts  = {}
    local Window   = {}

    -- ── AddScript ─────────────────────────────────────────────────────────
    function Window:AddScript(def)
        local name      = def.name      or "Script"
        local date      = def.date      or ""
        local icon      = def.icon      or nil
        local onLoad    = def.onLoad    or nil
        local statusUrl = def.statusUrl or nil  -- optional URL to raw status/date file

        local ITEM_H = 50
        local idx    = #scripts + 1

        local item = new("Frame",{
            Size=UDim2.new(1,0,0,ITEM_H),
            BackgroundColor3=C.bgItem,
            BorderSizePixel=0, ZIndex=3,
            BackgroundTransparency=1,
        }, scriptScroll)

        new("Frame",{
            Size=UDim2.new(1,0,0,1),
            Position=UDim2.new(0,0,1,-1),
            BackgroundColor3=C.bor,
            BackgroundTransparency=0.5,
            BorderSizePixel=0, ZIndex=4,
        }, item)

        local selBar = new("Frame",{
            Size=UDim2.new(0,2,0,0),
            Position=UDim2.new(0,0,0.5,0),
            BackgroundColor3=C.acc,
            BorderSizePixel=0, ZIndex=5,
        }, item)

        local ICON_S = 32
        local iconBg = new("Frame",{
            Size=UDim2.new(0,ICON_S,0,ICON_S),
            Position=UDim2.new(0,10,0.5,-ICON_S/2),
            BackgroundColor3=C.bgIn,
            BorderSizePixel=0, ZIndex=4,
        }, item)
        corner(iconBg, 3)
        stroke(iconBg, C.bor, 1)

        if icon then
            new("ImageLabel",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,
                Image=icon, ZIndex=5,
            }, iconBg)
        else
            new("TextLabel",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,
                Text=string.sub(name,1,1):upper(),
                TextColor3=C.accLt,
                FontFace=FONT, TextSize=15, ZIndex=5,
            }, iconBg)
        end

        -- status dot on icon corner (green/red based on statusUrl)
        local readyDot = new("Frame",{
            Size=UDim2.new(0,7,0,7),
            Position=UDim2.new(1,-3,1,-3),
            BackgroundColor3=C.txtD,  -- default grey until checked
            BorderSizePixel=0, ZIndex=6,
        }, iconBg)
        corner(readyDot, 4)
        stroke(readyDot, C.bgIn, 1)

        local TX = 10 + ICON_S + 10

        local nameLbl = new("TextLabel",{
            Size=UDim2.new(1,-(TX+8),0,16),
            Position=UDim2.new(0,TX,0,11),
            BackgroundTransparency=1,
            Text=name,
            TextColor3=C.accLt,
            FontFace=FONT, TextSize=13,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4,
        }, item)

        local dateLbl = new("TextLabel",{
            Size=UDim2.new(1,-(TX+8),0,12),
            Position=UDim2.new(0,TX,0,28),
            BackgroundTransparency=1,
            Text="Updated " .. date,
            TextColor3=C.txtD,
            FontFace=FONT, TextSize=10,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4,
        }, item)

        -- fetch statusUrl if provided
        if statusUrl then
            task.spawn(function()
                local ok2, result = pcall(function()
                    return game:HttpGet(statusUrl)
                end)
                if ok2 and result then
                    local trimmed = result:match("^%s*(.-)%s*$")
                    -- update date label with first line if it looks like a date
                    local firstLine = trimmed:match("^([^\n]+)")
                    if firstLine and firstLine ~= "" then
                        dateLbl.Text = "Updated " .. firstLine
                    end
                    -- set dot color
                    if isNotReady(trimmed) then
                        readyDot.BackgroundColor3 = C.red
                    else
                        readyDot.BackgroundColor3 = C.green
                    end
                else
                    readyDot.BackgroundColor3 = C.red
                end
            end)
        else
            readyDot.BackgroundColor3 = C.green
        end

        local hitbox = new("TextButton",{
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,
            Text="", ZIndex=6,
        }, item)

        local entry = {item=item, name=name, onLoad=onLoad, nameLbl=nameLbl, selBar=selBar, iconBg=iconBg}
        table.insert(scripts, entry)

        local function selectEntry()
            if selected and selected ~= entry then
                local prev = selected
                tw(prev.item,    {BackgroundColor3=C.bgItem, BackgroundTransparency=1}, T_MED)
                tw(prev.nameLbl, {TextColor3=C.accLt}, T_FAST)
                tw(prev.selBar,  {Size=UDim2.new(0,2,0,0), Position=UDim2.new(0,0,0.5,0)}, T_MED)
            end
            selected = entry
            tw(item,    {BackgroundColor3=C.itemSel, BackgroundTransparency=0}, T_MED)
            tw(nameLbl, {TextColor3=C.acc}, T_FAST)
            tw(selBar,  {Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,0,0,0)}, T_SPRING)
            -- push notification on select
            pushNotif("Script Selected", entry.name, C.acc)
        end

        hitbox.MouseEnter:Connect(function()
            if selected ~= entry then
                tw(item, {BackgroundColor3=C.itemHov, BackgroundTransparency=0}, T_FAST)
            end
        end)
        hitbox.MouseLeave:Connect(function()
            if selected ~= entry then
                tw(item, {BackgroundColor3=C.bgItem, BackgroundTransparency=1}, T_FAST)
            end
        end)
        hitbox.MouseButton1Click:Connect(function()
            selectEntry()
        end)

        task.delay(0.05*idx, function()
            if not item.Parent then return end
            tw(item, {BackgroundTransparency = selected==entry and 0 or 1}, T_MED)
        end)

        if #scripts == 1 then
            task.defer(selectEntry)
        end
    end

    -- ── SetStatus ─────────────────────────────────────────────────────────
    function Window:SetStatus(lines)
        for _, c in ipairs(statusBody:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end
        tw(statusDot, {BackgroundColor3=C.acc}, T_FAST)
        for i, def in ipairs(lines) do
            task.delay(0.08*(i-1), function()
                appendStatus(def.text or "", def.color)
            end)
        end
    end

    -- ── OnLoad ────────────────────────────────────────────────────────────
    function Window:OnLoad(cb)
        loadBtn.MouseButton1Click:Connect(function()
            if selected then
                local sname = selected.name or "Unknown"
                -- output to status
                appendStatus("► Loading: " .. sname, "accent")
                -- notification
                pushNotif("Loading Script", sname, C.accLt)
                if selected.onLoad then selected.onLoad() end
                if cb then cb(selected) end
                task.delay(0.5, function()
                    appendStatus("✓ Loaded: " .. sname, "green")
                end)
            else
                appendStatus("⚠ No script selected.", "yellow")
                pushNotif("No Script", "Please select a script first.", C.yellow)
            end
        end)
    end

    function Window:OnExit(cb)
        exitBtn.MouseButton1Click:Connect(function()
            tw(bgOverlay, {BackgroundTransparency=0}, ease(0.2))
            tw(win, {BackgroundTransparency=1, Position=UDim2.new(0.5,-W/2,0.5,-H/2+16)}, ease(0.2))
            task.delay(0.22, function()
                if cb then cb() end
                sg:Destroy()
                if notifSG then notifSG:Destroy() end
            end)
        end)
    end

    function Window:AddOption(text, danger, cb)
        local btn = makeBtn(text, danger)
        btn.MouseButton1Click:Connect(function()
            if cb then cb(selected) end
        end)
    end

    function Window:Notify(title, body, color)
        pushNotif(title, body, color)
    end

    function Window:Destroy()
        sg:Destroy()
        if notifSG then notifSG:Destroy() end
    end

    task.spawn(function()
        tw(bgOverlay, {BackgroundTransparency=0.55}, ease(0.3))
        task.wait(0.05)
        tw(win, {
            BackgroundTransparency=0,
            Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        }, T_SPRING)
        winStroke.Transparency = 0
    end)

    return Window
end

return Loader
