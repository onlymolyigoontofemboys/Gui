local _nSG, _nStack, _nIdx = nil, nil, 0

local function _ensureNotif()
    if _nSG and _nSG.Parent then return end
    _nSG = new("ScreenGui",{
        Name="LdrNotifs", ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling, DisplayOrder=999,
    }, CG)
    _nStack = new("Frame",{
        Size=UDim2.new(0,270,1,0),
        Position=UDim2.new(1,-282,0,0),
        BackgroundTransparency=1, BorderSizePixel=0, ZIndex=200,
    }, _nSG)
    local ul = vlist(_nStack, 5)
    ul.VerticalAlignment = Enum.VerticalAlignment.Bottom
    pad(_nStack, 0, 14, 0, 0)
end

local function pushNotif(title, body, col)
    _ensureNotif()
    col = col or C.acc
    _nIdx += 1

    local card = new("Frame",{
        Size=UDim2.new(1,0,0,60),
        BackgroundColor3=C.bgIn,
        BorderSizePixel=0, ZIndex=201,
        BackgroundTransparency=1,
        LayoutOrder=_nIdx,
        ClipsDescendants=true,
    }, _nStack)
    corner(card, 5)
    stroke(card, C.bor, 1)

    -- top accent line
    new("Frame",{
        Size=UDim2.new(1,0,0,1),
        BackgroundColor3=col, BorderSizePixel=0, ZIndex=202,
    }, card)
    -- left bar
    local bar = new("Frame",{
        Size=UDim2.new(0,3,1,0),
        BackgroundColor3=col, BorderSizePixel=0, ZIndex=202,
    }, card)
    corner(bar, 2)

    new("TextLabel",{
        Size=UDim2.new(1,-16,0,18),
        Position=UDim2.new(0,12,0,7),
        BackgroundTransparency=1,
        Text=title, TextColor3=C.txtH,
        FontFace=FONT, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=203,
    }, card)
    new("TextLabel",{
        Size=UDim2.new(1,-16,0,20),
        Position=UDim2.new(0,12,0,26),
        BackgroundTransparency=1,
        Text=body, TextColor3=C.txt,
        FontFace=FONT, TextSize=10,
        TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true, ZIndex=203,
    }, card)

    -- progress bar
    local pbg = new("Frame",{
        Size=UDim2.new(1,0,0,2),
        Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=C.bor, BorderSizePixel=0, ZIndex=204,
    }, card)
    local pp = new("Frame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundColor3=col, BorderSizePixel=0, ZIndex=205,
    }, pbg)

    -- slide in from right
    card.Position = UDim2.new(1.06, 0, 0, 0)
    tw(card, {BackgroundTransparency=0, Position=UDim2.new(0,0,0,0)}, T_SPRING)
    tw(pp, {Size=UDim2.new(0,0,1,0)}, ease(4, Enum.EasingStyle.Linear))

    task.delay(4.1, function()
        if not card.Parent then return end
        -- smooth slide-out fade
        tw(card, {
            BackgroundTransparency=1,
            Position=UDim2.new(1.06,0,0,0),
        }, ease(0.32, Enum.EasingStyle.Quart, Enum.EasingDirection.In))
        task.delay(0.34, function()
            if card.Parent then card:Destroy() end
        end)
    end)
end

