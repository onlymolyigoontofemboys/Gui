-- ── Tween helpers ─────────────────────────────────────────────────────────
local function ease(t, s, d)
    return TweenInfo.new(t, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out)
end
local T_FAST   = ease(0.14)
local T_MED    = ease(0.24)
local T_SPRING = ease(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

local function tw(obj, props, ti)
    TS:Create(obj, ti or T_FAST, props):Play()
end

-- ── Instance helpers ──────────────────────────────────────────────────────
local function new(cl, props, parent)
    local o = Instance.new(cl)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end
local function corner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 3); c.Parent = p
end
local function stroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or C.bor; s.Thickness = t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = p; return s
end
local function pad(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop=UDim.new(0,t or 0); u.PaddingBottom=UDim.new(0,b or 0)
    u.PaddingLeft=UDim.new(0,l or 0); u.PaddingRight=UDim.new(0,r or 0)
    u.Parent = p
end
local function vlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Vertical
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0,gap or 0); l.Parent=p; return l
end
local function typewrite(lbl, text, speed)
    speed = speed or 0.025
    task.spawn(function()
        for i = 1, #text do
            if not lbl or not lbl.Parent then return end
            lbl.Text = string.sub(text, 1, i)
            task.wait(speed)
        end
    end)
end

-- ── Status-file keywords that mean "not ready" ────────────────────────────
local BAD_KEYWORDS = { "none", "not done", "update not finish", "not finish" }
local function isNotReady(content)
    if not content or content:gsub("%s","") == "" then return true end
    local low = content:lower()
    for _, kw in ipairs(BAD_KEYWORDS) do
        if low:find(kw, 1, true) then return true end
    end
    return false
end

-- ── Notification queue ────────────────────────────────────────────────────
local notifSG    = nil
local notifStack = nil
local notifCount = 0

local function ensureNotifGui()
    if notifSG and notifSG.Parent then return end
    notifSG = new("ScreenGui", {
        Name="LoaderNotifs", ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 999,
    }, CG)
    notifStack = new("Frame", {
        Size=UDim2.new(0, 260, 1, 0),
        Position=UDim2.new(1, -270, 0, 0),
        BackgroundTransparency=1,
        BorderSizePixel=0,
        ZIndex=100,
    }, notifSG)
    local ul = vlist(notifStack, 6)
    ul.VerticalAlignment = Enum.VerticalAlignment.Bottom
    pad(notifStack, 0, 12, 0, 0)
end

local function pushNotif(title, body, color)
    ensureNotifGui()
    notifCount += 1
    color = color or C.acc

    local card = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 60),
        BackgroundColor3 = C.bgIn,
        BorderSizePixel  = 0,
        ZIndex           = 101,
        BackgroundTransparency = 0,
        LayoutOrder      = notifCount,
    }, notifStack)
    corner(card, 4)
    stroke(card, C.bor, 1)

    -- accent left bar
    local bar = new("Frame", {
        Size=UDim2.new(0,3,1,0),
        BackgroundColor3=color,
        BorderSizePixel=0, ZIndex=102,
    }, card)
    corner(bar, 2)

    new("TextLabel", {
        Size=UDim2.new(1,-16,0,16),
        Position=UDim2.new(0,12,0,8),
        BackgroundTransparency=1,
        Text=title,
        TextColor3=C.txtH,
        FontFace=FONT, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=102,
    }, card)

    new("TextLabel", {
        Size=UDim2.new(1,-16,0,24),
        Position=UDim2.new(0,12,0,26),
        BackgroundTransparency=1,
        Text=body,
        TextColor3=C.txt,
        FontFace=FONT, TextSize=10,
        TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true,
        ZIndex=102,
    }, card)

    -- slide-in from right
    card.Position = UDim2.new(1.1, 0, card.Position.Y.Scale, card.Position.Y.Offset)
    tw(card, {Position=UDim2.new(0,0,card.Position.Y.Scale,card.Position.Y.Offset)}, T_SPRING)

    -- progress bar at bottom
    local progBg = new("Frame", {
        Size=UDim2.new(1,0,0,2),
        Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=C.bor, BorderSizePixel=0, ZIndex=103,
    }, card)
    local prog = new("Frame", {
        Size=UDim2.new(1,0,1,0),
        BackgroundColor3=color, BorderSizePixel=0, ZIndex=104,
    }, progBg)
    tw(prog, {Size=UDim2.new(0,0,1,0)}, ease(3.8, Enum.EasingStyle.Linear))

    task.delay(4, function()
        if not card.Parent then return end
        tw(card, {BackgroundTransparency=1, Position=UDim2.new(1.1,0,card.Position.Y.Scale,card.Position.Y.Offset)}, ease(0.2))
        task.delay(0.22, function()
            if card.Parent then card:Destroy() end
        end)
    end)
end

