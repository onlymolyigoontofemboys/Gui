    end

    -- ── Button factory ────────────────────────────────────────────────────
    local function makeBtn(text, danger)
        local btn = new("TextButton",{
            Size=UDim2.new(1,0,0,28),
            BackgroundColor3=C.btnBg,
            BorderSizePixel=0,
            Text=text,
            TextColor3=danger and C.red or C.txt,
            FontFace=FONT, TextSize=12,
            AutoButtonColor=false, ZIndex=4,
            BackgroundTransparency=1,
        }, optArea)
        corner(btn, 3)
        local bs = stroke(btn, danger and Color3.fromRGB(60,20,20) or C.bor, 1)

        btn.MouseEnter:Connect(function()
            tw(btn,{BackgroundColor3=danger and C.redDk or C.btnHov, BackgroundTransparency=0, TextColor3=danger and C.accGlow or C.txtH},T_FAST)
            bs.Color = danger and C.accLt or C.borLt
        end)
        btn.MouseLeave:Connect(function()
            tw(btn,{BackgroundColor3=C.btnBg, BackgroundTransparency=1, TextColor3=danger and C.red or C.txt},T_FAST)
            bs.Color = danger and Color3.fromRGB(60,20,20) or C.bor
        end)
        btn.MouseButton1Down:Connect(function()
            tw(btn,{Size=UDim2.new(1,-4,0,26)},ease(0.07))
        end)
        btn.MouseButton1Up:Connect(function()
            tw(btn,{Size=UDim2.new(1,0,0,28)},T_SPRING)
        end)
        btn.MouseButton1Click:Connect(function()
            animateLoadBar()
        end)
        return btn
    end

    local loadBtn = makeBtn("Load",  false)
    local exitBtn = makeBtn("Exit",  true)

    -- ── Script entries ────────────────────────────────────────────────────
    local selected = nil
    local scripts  = {}
    local Window   = {}

    function Window:AddScript(def)
        local name      = def.name      or "Script"
        local date      = def.date      or ""
        local icon      = def.icon      or nil
        local onLoad    = def.onLoad    or nil
        local statusUrl = def.statusUrl or nil

        local ITEM_H = 54
        local idx    = #scripts + 1

        local item = new("Frame",{
            Size=UDim2.new(1,0,0,ITEM_H),
            BackgroundColor3=C.bgItem,
            BorderSizePixel=0, ZIndex=3,
            BackgroundTransparency=1,
        }, scriptScroll)

        new("Frame",{
            Size=UDim2.new(1,0,0,1),
            Position=UDim2.new(0,0,1,-1),
            BackgroundColor3=C.bor,
            BackgroundTransparency=0.55,
            BorderSizePixel=0, ZIndex=4,
        }, item)

        local selBar = new("Frame",{
            Size=UDim2.new(0,2,0,0),
            Position=UDim2.new(0,0,0.5,0),
            BackgroundColor3=C.acc,
            BorderSizePixel=0, ZIndex=5,
        }, item)
        corner(selBar,1)

        local ICON_S = 34
        local iconBg = new("Frame",{
            Size=UDim2.new(0,ICON_S,0,ICON_S),
            Position=UDim2.new(0,10,0.5,-ICON_S/2),
            BackgroundColor3=C.bgIn,
            BorderSizePixel=0, ZIndex=4,
        }, item)
        corner(iconBg,4)
        stroke(iconBg, C.bor, 1)

        if icon then
            new("ImageLabel",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, Image=icon, ZIndex=5,
            }, iconBg)
        else
            new("TextLabel",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,
                Text=string.sub(name,1,1):upper(),
                TextColor3=C.accLt, FontFace=FONT, TextSize=16, ZIndex=5,
            }, iconBg)
        end

        -- Status dot (top-right of icon)
        local readyDot = new("Frame",{
            Size=UDim2.new(0,8,0,8),
            Position=UDim2.new(1,-4,0,-4),
            BackgroundColor3=C.txtD,
            BorderSizePixel=0, ZIndex=7,
        }, iconBg)
        corner(readyDot,5)
        stroke(readyDot, C.bgIn, 1.5)

        local TX = 10+ICON_S+10

        local nameLbl = new("TextLabel",{
            Size=UDim2.new(1,-(TX+8),0,17),
            Position=UDim2.new(0,TX,0,9),
            BackgroundTransparency=1,
            Text=name, TextColor3=C.accLt,
            FontFace=FONT, TextSize=13,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4,
        }, item)

        local dateLbl = new("TextLabel",{
            Size=UDim2.new(1,-(TX+8),0,12),
            Position=UDim2.new(0,TX,0,27),
            BackgroundTransparency=1,
            Text="Updated "..date, TextColor3=C.txtD,
            FontFace=FONT, TextSize=10,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4,
        }, item)

        -- tag badge
        local tagFrame = new("Frame",{
            Size=UDim2.new(0,64,0,11),
            Position=UDim2.new(0,TX,0,40),
            BackgroundColor3=C.greenDk,
            BorderSizePixel=0, ZIndex=4, Visible=false,
        }, item)
        corner(tagFrame, 2)
        local tagLbl = new("TextLabel",{
            Size=UDim2.new(1,-6,1,0),
            Position=UDim2.new(0,4,0,0),
            BackgroundTransparency=1,
            Text="", TextColor3=C.green,
            FontFace=FONT, TextSize=8,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
        }, tagFrame)

        if statusUrl then
            task.spawn(function()
                local ok2, result = pcall(function() return game:HttpGet(statusUrl) end)
                if ok2 and result then
                    local trimmed = result:match("^%s*(.-)%s*$") or ""
                    local firstLine = trimmed:match("^([^\n\r]+)") or ""
                    if firstLine ~= "" then
                        dateLbl.Text = "Updated "..firstLine
                    end
                    if isNotReady(trimmed) then
                        readyDot.BackgroundColor3 = C.red
                        tagFrame.BackgroundColor3 = C.redDk
                        tagFrame.Size = UDim2.new(0,58,0,11)
                        tagLbl.Text = "NOT READY"
                        tagLbl.TextColor3 = C.red
                    else
                        readyDot.BackgroundColor3 = C.green
                        tagFrame.BackgroundColor3 = C.greenDk
                        tagFrame.Size = UDim2.new(0,66,0,11)
                        tagLbl.Text = "UP TO DATE"
                        tagLbl.TextColor3 = C.green
                    end
                    tagFrame.Visible = true
                else
                    readyDot.BackgroundColor3 = C.yellow
                    tagFrame.BackgroundColor3 = C.yellowDk
                    tagFrame.Size = UDim2.new(0,60,0,11)
                    tagLbl.Text = "NO STATUS"
                    tagLbl.TextColor3 = C.yellow
                    tagFrame.Visible = true
                end
            end)
        else
            readyDot.BackgroundColor3 = C.green
        end

        local hitbox = new("TextButton",{
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, Text="", ZIndex=6,
        }, item)

        local entry = {item=item, name=name, onLoad=onLoad, nameLbl=nameLbl, selBar=selBar}
        table.insert(scripts, entry)

        local function selectEntry()
            if selected and selected~=entry then
                local prev = selected
                tw(prev.item,    {BackgroundColor3=C.bgItem, BackgroundTransparency=1}, T_MED)
                tw(prev.nameLbl, {TextColor3=C.accLt}, T_FAST)
                tw(prev.selBar,  {Size=UDim2.new(0,2,0,0), Position=UDim2.new(0,0,0.5,0)}, T_MED)
            end
            selected = entry
            tw(item,    {BackgroundColor3=C.itemSel, BackgroundTransparency=0}, T_MED)
            tw(nameLbl, {TextColor3=C.acc}, T_FAST)
            tw(selBar,  {Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,0,0,0)}, T_SPRING)
            pushNotif("Script Selected", entry.name, C.acc)
            appendLog("► Selected: "..entry.name, "accent")
        end

        hitbox.MouseEnter:Connect(function()
            if selected~=entry then tw(item,{BackgroundColor3=C.itemHov, BackgroundTransparency=0},T_FAST) end
        end)
        hitbox.MouseLeave:Connect(function()
            if selected~=entry then tw(item,{BackgroundColor3=C.bgItem, BackgroundTransparency=1},T_FAST) end
        end)
        hitbox.MouseButton1Click:Connect(selectEntry)

        task.delay(0.04*idx, function()
            if not item.Parent then return end
            tw(item,{BackgroundTransparency=selected==entry and 0 or 1},T_MED)
        end)
        if #scripts==1 then task.defer(selectEntry) end
    end

    -- ── SetStatus ─────────────────────────────────────────────────────────
    function Window:SetStatus(lines)
        for _, c in ipairs(statusBody:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end
        setDotState("ok")
        for i, def in ipairs(lines) do
            task.delay(0.07*(i-1), function()
                appendLog(def.text or "", def.color or "default")
            end)
        end
    end

    -- ── SetState ──────────────────────────────────────────────────────────
    function Window:SetState(state)
        setDotState(state)
    end

    -- ── OnLoad ────────────────────────────────────────────────────────────
    function Window:OnLoad(cb)
        loadBtn.MouseButton1Click:Connect(function()
            if selected then
                local sname = selected.name
                appendLog("────────────────────", "dim")
                appendLog("► Initializing: "..sname, "cyan")
                setDotState("warn")
                pushNotif("Loading", sname, C.accLt)
                if selected.onLoad then
                    local ok3, err = pcall(selected.onLoad)
                    if ok3 then
                        task.delay(0.4, function()
                            appendLog("✓ Loaded: "..sname, "success")
                            appendLog("────────────────────", "dim")
                            setDotState("ok")
                            pushNotif("Loaded!", sname.." ready.", C.green)
                        end)
                    else
                        appendLog("✗ Error: "..tostring(err), "error")
                        appendLog("────────────────────", "dim")
                        setDotState("error")
                        pushNotif("Error", tostring(err), C.red)
                    end
                else
                    task.delay(0.4, function()
                        appendLog("✓ Loaded: "..sname, "success")
                        setDotState("ok")
                        pushNotif("Loaded!", sname.." ready.", C.green)
                    end)
                end
                if cb then cb(selected) end
            else
                appendLog("⚠ No script selected!", "warn")
                setDotState("warn")
                pushNotif("Warning", "Select a script first!", C.yellow)
            end
        end)
    end

    -- ── OnExit ────────────────────────────────────────────────────────────
    function Window:OnExit(cb)
        exitBtn.MouseButton1Click:Connect(function()
            tw(win, {
                BackgroundTransparency=1,
                Position=UDim2.new(0.5,-W/2,0.5,-H/2+14),
            }, T_OUT)
            tw(vignette, {ImageTransparency=1}, ease(0.26))
            task.delay(0.30, function()
                if cb then cb() end
                sg:Destroy()
                if _nSG then _nSG:Destroy() end
            end)
        end)
    end

    -- ── AddOption ─────────────────────────────────────────────────────────
    function Window:AddOption(text, danger, cb)
        local btn = makeBtn(text, danger)
        btn.MouseButton1Click:Connect(function()
            if cb then cb(selected) end
        end)
    end

    -- ── AddDevlog ─────────────────────────────────────────────────────────
    function Window:AddDevlog(scriptName, message, date, color)
        local col = LOG_COL[color or "accent"] or C.acc
        addDevlogCard(scriptName, message, date, col)
    end

    -- ── Log ───────────────────────────────────────────────────────────────
    function Window:Log(text, level)
        appendLog(text, level)
    end

    -- ── Notify ────────────────────────────────────────────────────────────
    function Window:Notify(title, body, color)
        pushNotif(title, body, LOG_COL[color or "accent"] or C.acc)
    end

    function Window:Destroy()
        sg:Destroy()
        if _nSG then _nSG:Destroy() end
    end

    -- ── Entrance animation ────────────────────────────────────────────────
    task.spawn(function()
        tw(vignette,{ImageTransparency=0.68}, ease(0.38))
        task.wait(0.05)
        tw(win,{
            BackgroundTransparency=0,
            Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        }, T_SPRING)
        winStroke.Transparency = 0
    end)

    return Window
end

return Loader
